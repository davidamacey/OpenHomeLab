# ===========================================================================
# Speedtest Tracker — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

SPEEDTEST_PORT=7900

# REQUIRED — generate with: openssl rand -base64 32
# Must start with "base64:" prefix
SPEEDTEST_APP_KEY=base64:

# Cron schedule for speed tests (default: every 6 hours)
SPEEDTEST_SCHEDULE=0 */6 * * *

# Specific Ookla server IDs (comma-separated), or leave blank for auto-select
SPEEDTEST_SERVERS=

TZ=America/New_York
PUID=1000
PGID=1000
DATA_PATH=/mnt/nas/appdata

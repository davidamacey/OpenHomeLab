# ===========================================================================
# AdGuard Home — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# NOTE: Port 53 (DNS) may be in use by systemd-resolved. Use 5353 (default)
#       or free up port 53 with:
#         sudo systemctl stop systemd-resolved
#         sudo systemctl disable systemd-resolved
#       Then change AGH_DNS_PORT=53.
# ===========================================================================

AGH_PORT=3080
AGH_DNS_PORT=5353

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

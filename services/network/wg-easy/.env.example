# ===========================================================================
# wg-easy — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# Generate PASSWORD_HASH with:
#   docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'your_password' | cat
# ===========================================================================

WG_HOST=your.public.ip.or.domain   # REQUIRED — public IP or DDNS hostname

# bcrypt hash of the web UI admin password — REQUIRED
# Generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'yourpassword'
WG_PASSWORD_HASH=

WG_PORT=51820
WG_UI_PORT=51821
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

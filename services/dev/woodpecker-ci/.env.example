# ===========================================================================
# Woodpecker CI — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

WOODPECKER_PORT=3610

# Public hostname or IP of this server (used in OAuth redirect URLs)
WOODPECKER_HOST=localhost

# REQUIRED: random shared secret between server and agents
# Generate with: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=change_me_strong_random_secret

# Max concurrent workflows per agent
WOODPECKER_MAX_WORKFLOWS=4

# Allow public registration (false = invite only)
WOODPECKER_OPEN=false

# Gitea OAuth2 — create app at <gitea>/user/settings/applications
WOODPECKER_GITEA_URL=http://gitea:3000
WOODPECKER_GITEA_CLIENT=
WOODPECKER_GITEA_SECRET=

TZ=America/New_York

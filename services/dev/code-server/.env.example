# ===========================================================================
# code-server — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# Set either PASSWORD or HASHED_PASSWORD (not both).
# Generate hashed password with: echo -n "your_password" | npx argon2-cli -e
# ===========================================================================

CODE_SERVER_PORT=3600

# Plain text password (less secure; prefer HASHED_PASSWORD)
CODE_SERVER_PASSWORD=change_me

# Argon2 hashed password (preferred; leave blank if using PASSWORD)
CODE_SERVER_HASHED_PASSWORD=

# Optional sudo password inside the container
CODE_SERVER_SUDO_PASSWORD=

TZ=America/New_York
PUID=1000
PGID=1000
DATA_PATH=/mnt/nas/appdata

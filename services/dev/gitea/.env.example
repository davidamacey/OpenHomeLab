# ===========================================================================
# Gitea — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

GITEA_PORT=3500
GITEA_SSH_PORT=2222

# Domain or IP used in clone URLs (e.g. gitea.home.lan or 192.168.1.10)
GITEA_DOMAIN=localhost

# PostgreSQL credentials
GITEA_DBNAME=gitea
GITEA_DBUSER=gitea
GITEA_DBPASS=change_me_strong_password

TZ=America/New_York
PUID=1000
PGID=1000
DATA_PATH=/mnt/nas/appdata

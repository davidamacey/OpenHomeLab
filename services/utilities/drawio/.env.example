# ===========================================================================
# draw.io — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

DRAWIO_HTTP_PORT=8081
DRAWIO_HTTPS_PORT=8443

# Self-signed certificate fields (used for HTTPS endpoint)
DRAWIO_DOMAIN=your-server-hostname-or-ip
DRAWIO_ORG_UNIT=IT
DRAWIO_ORG=HomeLab
DRAWIO_CITY=Your City
DRAWIO_STATE=Your State
DRAWIO_COUNTRY=US

TZ=America/New_York

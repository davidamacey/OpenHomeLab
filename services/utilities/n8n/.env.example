# ===========================================================================
# n8n — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

N8N_PORT=5678

# REQUIRED: encryption key for credentials — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_strong_random_key

# Hostname used for webhook URLs (your server's IP or domain)
N8N_HOST=localhost

# PostgreSQL credentials
N8N_DBNAME=n8n
N8N_DBUSER=n8n
N8N_DBPASS=change_me_strong_password

# Basic auth (recommended for LAN-only or internet-exposed instances)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

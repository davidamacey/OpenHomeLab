# ===========================================================================
# Paperless-ngx — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

PAPERLESS_PORT=8070

# Database
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=CHANGE_ME_strong_random_password

# Secret key — generate: openssl rand -hex 32
PAPERLESS_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# OCR language(s): comma-separated Tesseract codes (eng, fra, deu, spa, etc.)
PAPERLESS_OCR_LANGUAGE=eng

# Storage paths
DATA_PATH=/mnt/nas/appdata

PUID=1000
PGID=1000
TZ=America/New_York

# ===========================================================================
# Stirling PDF — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# NOTE: Default port is 8080, which conflicts with Nextcloud AIO admin UI.
#       Change STIRLING_PORT to 8085 (or similar) if running both.
# ===========================================================================

STIRLING_PORT=8080

TZ=America/New_York

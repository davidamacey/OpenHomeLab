# ===========================================================================
# Vaultwarden — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

VAULTWARDEN_PORT=8222

# Admin panel access token — generate: openssl rand -base64 48
ADMIN_TOKEN=CHANGE_ME_generate_with_openssl_rand_base64_48

# Set to false once you've created your account(s)
SIGNUPS_ALLOWED=true

# Your domain (required for HTTPS — clients won't connect without it)
# Set to your reverse proxy URL, e.g. https://vault.homelab.local
VAULTWARDEN_DOMAIN=http://localhost:8222

# Optional SMTP for email (2FA, password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=vaultwarden@homelab.local

DATA_PATH=/mnt/nas/appdata
TZ=America/New_York

# ===========================================================================
# BookStack — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

BOOKSTACK_PORT=6875
BOOKSTACK_URL=http://localhost:6875    # or your reverse proxy URL

# App key — generate: echo "base64:$(openssl rand -base64 32)"
APP_KEY=CHANGE_ME_generate_base64_openssl_rand_32

# Database
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
MYSQL_DATABASE=bookstack
MYSQL_USER=bookstack
MYSQL_PASSWORD=CHANGE_ME_strong_random_password

# Storage
DATA_PATH=/mnt/nas/appdata

PUID=1000
PGID=1000
TZ=America/New_York

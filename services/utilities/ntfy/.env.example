# ===========================================================================
# ntfy — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# Port for ntfy (default: 80 — change if port 80 is in use)
NTFY_PORT=80

# Cloudflare Tunnel token (only needed if using the tunnel service)
# Get one at: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
CLOUDFLARE_TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE

TZ=America/New_York

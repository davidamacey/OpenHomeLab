# ===========================================================================
# Duplicati — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

DUPLICATI_PORT=8210

# Source (what to back up) — mounted read-only into container
BACKUP_SOURCE_PATH=/mnt/nas/appdata

# Local backup destination — for local jobs
BACKUP_DEST_PATH=/mnt/nas/backups

# Cloud storage credentials are configured in the Duplicati web UI, not here.
# Supports Backblaze B2, AWS S3, Google Drive, SFTP, and more.

PUID=1000
PGID=1000
TZ=America/New_York

# ===========================================================================
# OpenProcessor — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# GPU device for Triton server and API (0=A6000#1, 1=3080Ti, 2=A6000#2)
GPU_DEVICE_ID=2

# Ports (change only if conflicts exist)
OP_TRITON_HTTP_PORT=4600
OP_TRITON_GRPC_PORT=4601
OP_TRITON_METRICS_PORT=4602
OP_API_PORT=4603
OP_OPENSEARCH_PORT=4607
OP_OPENSEARCH_DASH_PORT=4608

# Storage paths (models must be pre-converted to TensorRT format)
NAS_PATH=/mnt/nas
TZ=America/New_York

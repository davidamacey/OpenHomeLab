# ===========================================================================
# OpenAudio — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Source: https://github.com/davidamacey/OpenAudio
# ===========================================================================

IMAGE_TAG=latest

# --- Ports (547X range) ---
OPENAUDIO_FRONTEND_PORT=5473
OPENAUDIO_BACKEND_PORT=5474
OPENAUDIO_FLOWER_PORT=5475
OPENAUDIO_POSTGRES_PORT=5476
OPENAUDIO_REDIS_PORT=5477
OPENAUDIO_MINIO_PORT=5478
OPENAUDIO_MINIO_CONSOLE_PORT=5479

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_DB=openaudio
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_random_password

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_password
MINIO_PUBLIC_URL=

# --- Security ---
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
AUTH_ENABLED=false

# --- GPU ---
GPU_DEVICE_ID=2    # Which GPU for ML workers (torch, SAM)
TORCH_DEVICE=auto
USE_GPU=auto

# --- HuggingFace (required for gated models like PyAnnote) ---
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE

# --- Model cache ---
MODEL_CACHE_DIR=/mnt/nas/appdata/openaudio/models

# --- Admin account ---
DEFAULT_ADMIN_EMAIL=admin@openaudio.local
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_strong_password

# --- Celery Flower ---
VITE_FLOWER_URL_PREFIX=flower

TZ=America/New_York
LOG_LEVEL=INFO

# ===========================================================================
# Video Upscaler — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Source: https://github.com/davidamacey/video-upscaler
# ===========================================================================

IMAGE_TAG=latest

# GPU to use (default: 0 = RTX A6000)
GPU_DEVICE_ID=0

# Source video path (READ ONLY — never write here)
SOURCE_PATH=/mnt/nas/tv_shows

# Output directory for upscaled videos
OUTPUT_DIR=/mnt/nvm/output

# Model weights (persisted named volume)
WEIGHTS_HOST_DIR=/mnt/nas/appdata/video-upscaler/weights

# Log and temp directories
LOG_DIR=/mnt/nas/appdata/video-upscaler/logs
TEMP_DIR=/tmp/video-upscaler    # use fast local disk, NOT NAS

TZ=America/New_York

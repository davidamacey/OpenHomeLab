# ===========================================================================
# OpenTranscribe — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Source: https://github.com/davidamacey/OpenTranscribe
# ===========================================================================

# Image version (use "latest" or pin e.g. "1.2.0")
IMAGE_TAG=latest

# --- Ports (all in 517X range to avoid conflicts) ---
OPENTRANSCRIBE_FRONTEND_PORT=5173
OPENTRANSCRIBE_BACKEND_PORT=5174
OPENTRANSCRIBE_FLOWER_PORT=5175
OPENTRANSCRIBE_POSTGRES_PORT=5176
OPENTRANSCRIBE_REDIS_PORT=5177
OPENTRANSCRIBE_MINIO_PORT=5178
OPENTRANSCRIBE_MINIO_CONSOLE_PORT=5179
OPENTRANSCRIBE_OPENSEARCH_PORT=5180
OPENTRANSCRIBE_OPENSEARCH_ADMIN_PORT=5181

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_DB=opentranscribe
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_SSLMODE=prefer

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_random_password

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_random_password
MINIO_KMS_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32
MINIO_KMS_AUTO_ENCRYPTION=on

# --- Security ---
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Celery Flower ---
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password
FLOWER_URL_PREFIX=flower

# --- GPU ---
GPU_DEVICE_ID=0    # Which GPU for transcription worker

# --- Whisper model ---
WHISPER_MODEL=large-v3-turbo    # or large-v3 for translation/non-English

# --- Model cache ---
MODEL_CACHE_DIR=/mnt/nas/appdata/opentranscribe/models

# --- LLM (optional — leave empty to disable) ---
LLM_PROVIDER=    # vllm, openai, ollama, anthropic, or empty

TZ=America/New_York

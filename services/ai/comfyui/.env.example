# ===========================================================================
# ComfyUI — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# HuggingFace token — required to download Flux model weights
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ComfyUI port (default: 8188)
COMFYUI_PORT=8188

# Set to true if your GPU has limited VRAM (< 12 GB)
LOW_VRAM=false

# NAS / storage base path
NAS_PATH=/mnt/nas
TZ=America/New_York

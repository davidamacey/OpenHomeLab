# ===========================================================================
# IOPaint — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

IOPAINT_PORT=7800

# Model to use. Options: lama, mat, zits, fcf, manga, powerpaint, brushnet, cv2
# lama is the default — fast, no HF token needed.
# powerpaint and brushnet require HF_TOKEN.
IOPAINT_MODEL=lama

# HuggingFace token — required for PowerPaint, BrushNet, and other gated models.
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

# ===========================================================================
# OpenRingDetector — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Source: https://github.com/davidamacey/OpenRingDetector
# ===========================================================================

# --- Database ---
DB_USER=ring
DB_PASSWORD=CHANGE_ME_strong_random_password
DB_NAME=ring_detector
DB_HOST=db
DB_PORT=5432
RING_DB_PORT=5433    # host-side published port

# --- Ring credentials ---
# Get via: ring-auth (interactive two-factor flow)
RING_EMAIL=your-ring-email@example.com
RING_PASSWORD=YOUR_RING_ACCOUNT_PASSWORD
RING_2FA_CODE=    # leave empty — filled interactively on first auth
RING_TOKEN=       # auto-populated after first auth; paste token here for subsequent runs

# --- Notifications (ntfy) ---
NTFY_URL=http://ntfy:80              # or your public ntfy URL
NTFY_TOPIC=ring-doorbell-alerts

# --- GPU ---
GPU_DEVICE_ID=1    # GPU for YOLO detection; default 1 = RTX 3080 Ti

# --- Storage ---
NAS_PATH=/mnt/nas

# --- Detection settings ---
DEPARTURE_TIMEOUT=300        # seconds of no motion before departure is recorded
CAPTIONER_ENABLED=false      # set true to enable Gemma 3 scene captioning
# OLLAMA_URL=http://ollama:11434  # required if CAPTIONER_ENABLED=true

TZ=America/New_York

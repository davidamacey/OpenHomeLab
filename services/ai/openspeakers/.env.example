# ===========================================================================
# OpenSpeakers — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Source: https://github.com/davidamacey/OpenSpeakers
# ===========================================================================

IMAGE_TAG=latest

# --- Ports (528X range) ---
OPENSPEAKERS_FRONTEND_PORT=5283
OPENSPEAKERS_BACKEND_PORT=5284
OPENSPEAKERS_POSTGRES_PORT=5285
OPENSPEAKERS_REDIS_PORT=5286

# --- Database ---
POSTGRES_DB=openspeakers
POSTGRES_USER=openspeakers
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# --- GPU ---
GPU_DEVICE_ID=0    # Single GPU; hot-swap model manager loads one model at a time

# --- Storage ---
AUDIO_OUTPUT_DIR=/mnt/nas/appdata/openspeakers/audio_output
MODEL_CACHE_DIR=/mnt/nas/appdata/openspeakers/models

TZ=America/New_York

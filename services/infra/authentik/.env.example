# ===========================================================================
# Authentik — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Docs: https://docs.goauthentik.io/docs/installation/docker-compose
# ===========================================================================

# Authentik version
AUTHENTIK_TAG=2025.6.1

# CRITICAL: Generate a strong secret key
# openssl rand 60 | base64 -w 0
AUTHENTIK_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_60_base64

# Database
POSTGRES_USER=authentik
POSTGRES_DB=authentik
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# Ports
AUTHENTIK_HTTP_PORT=9300
AUTHENTIK_HTTPS_PORT=9443

# Email (optional — for password resets and notifications)
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=YOUR_EMAIL_APP_PASSWORD
EMAIL_FROM=authentik@homelab.local

TZ=America/New_York

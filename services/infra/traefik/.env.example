# ===========================================================================
# Traefik — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# Ports (80/443 conflict with nginx-proxy — use only one reverse proxy on these ports)
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8090

# Let's Encrypt (for auto-SSL on a real domain)
ACME_EMAIL=your-email@example.com
DOMAIN=homelab.local    # or your real domain

# Dashboard security (set false to require auth in traefik.yml)
TRAEFIK_DASHBOARD_INSECURE=true

TZ=America/New_York

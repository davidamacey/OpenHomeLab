# ===========================================================================
# Watchtower — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

TZ=America/New_York

# Optional: ntfy notification URL when containers are updated
# Uncomment and set in docker-compose.yml WATCHTOWER_NOTIFICATION_URL
# NTFY_URL=http://your-ntfy-server/watchtower

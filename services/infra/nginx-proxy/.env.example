# ===========================================================================
# Nginx Proxy Manager — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# Default admin login: admin@example.com / changeme
# (you will be prompted to change both on first login)
# ===========================================================================

NPM_HTTP_PORT=80
NPM_ADMIN_PORT=81
NPM_HTTPS_PORT=443

TZ=America/New_York

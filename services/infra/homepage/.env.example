# ===========================================================================
# Homepage — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# Homepage requires YAML config files. See docs: https://gethomepage.dev
# Create your config directory and set HOMEPAGE_CONFIG_PATH below.
# ===========================================================================

HOMEPAGE_PORT=3000
HOMEPAGE_CONFIG_PATH=./config
HOMEPAGE_ALLOWED_HOSTS=localhost

TZ=America/New_York

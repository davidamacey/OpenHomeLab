# ===========================================================================
# Home Assistant — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# NOTE: Home Assistant uses host networking by default for device discovery.
#       The HA_PORT variable is only used if you switch to bridge networking.
# ===========================================================================

HA_PORT=8123

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

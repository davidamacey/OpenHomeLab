# ===========================================================================
# Zigbee2MQTT — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

Z2M_PORT=8885

# Path to your Zigbee USB coordinator dongle.
# Find it with: ls /dev/serial/by-id/
# Common examples: /dev/ttyUSB0, /dev/ttyACM0
ZIGBEE_ADAPTER=/dev/ttyUSB0

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

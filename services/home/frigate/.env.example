# ===========================================================================
# Frigate NVR — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Docs: https://docs.frigate.video/configuration/
# ===========================================================================

# Frigate version tag (stable | dev | specific version like 0.14.0)
FRIGATE_VERSION=stable

# RTSP password used in config.yml as {FRIGATE_RTSP_PASSWORD}
FRIGATE_RTSP_PASSWORD=CHANGE_ME_your_camera_rtsp_password

# Paths
FRIGATE_CONFIG_PATH=./config           # create config/config.yml here
NAS_PATH=/mnt/nas                      # recorded clips stored at ${NAS_PATH}/appdata/frigate/media

# GPU for object detection (default: 1 = RTX 3080 Ti)
GPU_DEVICE_ID=1

# Ports
FRIGATE_WEB_PORT=5000
FRIGATE_RTSP_PORT=8554
FRIGATE_WEBRTC_PORT=8555

TZ=America/New_York

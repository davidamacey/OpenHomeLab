# ===========================================================================
# Tandoor Recipes — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Docs: https://docs.tandoor.dev/install/docker/#docker-compose
# ===========================================================================

# Django secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets

# Database settings
DB_ENGINE=django.db.backends.postgresql
POSTGRES_HOST=tandoor-db
POSTGRES_PORT=5432
POSTGRES_USER=tandoor
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=tandoor

# Allowed hosts — set to your server IP or domain
ALLOWED_HOSTS=*

# Port (default: 9092)
TANDOOR_PORT=9092

# Data storage path
DATA_PATH=/mnt/nas/appdata

TZ=America/New_York

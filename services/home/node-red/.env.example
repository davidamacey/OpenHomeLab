# ===========================================================================
# Node-RED — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

NODE_RED_PORT=1880

# Optional: credential encryption secret (highly recommended for production)
# NODE_RED_SECRET=change_me_to_a_strong_random_string

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

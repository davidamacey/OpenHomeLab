# Mosquitto configuration — copy this file to:
# ${DATA_PATH}/mosquitto/config/mosquitto.conf
#
# This is a minimal anonymous-access config suitable for a trusted LAN.
# For production, enable authentication with a password file.
# Docs: https://mosquitto.org/man/mosquitto-conf-5.html

# MQTT over TCP
listener 1883
protocol mqtt

# MQTT over WebSocket (for browser-based clients and Node-RED dashboard)
listener 9001
protocol websockets

# Allow unauthenticated connections (LAN-only — disable if internet-exposed)
allow_anonymous true

# Persist messages across restarts
persistence true
persistence_location /mosquitto/data/

# Logging
log_dest file /mosquitto/log/mosquitto.log
log_type error
log_type warning
log_type notice
log_type information

# Uncomment to require username/password:
# allow_anonymous false
# password_file /mosquitto/config/passwd
# (create with: docker exec mosquitto mosquitto_passwd -c /mosquitto/config/passwd <username>)

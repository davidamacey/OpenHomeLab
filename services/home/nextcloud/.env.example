# ===========================================================================
# Nextcloud AIO — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# Where Nextcloud data (files) will be stored on the host
NAS_PATH=/mnt/nas

# Ports (default: 80/8080/8400 — change if port 80 is in use)
NEXTCLOUD_HTTP_PORT=80
NEXTCLOUD_ADMIN_PORT=8080
NEXTCLOUD_HTTPS_PORT=8400

TZ=America/New_York

# ===========================================================================
# PeerTube — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# This config is pre-set for a PRIVATE instance:
#   - Public signup disabled (admin adds users manually)
#   - Federation disabled (no ActivityPub, not visible on PeerTube index)
#   - All of this is adjustable via Admin → Configuration after first login
#
# FIRST ADMIN SETUP — set admin password after first start:
#   docker exec -it peertube /bin/bash -c \
#     "cd /app && NODE_CONFIG_DIR=/config NODE_ENV=production \
#      node dist/scripts/reset-password.js -u root"
# ===========================================================================

PEERTUBE_PORT=7960

# LAN IP or hostname (used in video embed URLs and email links)
PEERTUBE_HOSTNAME=localhost

# REQUIRED: random secret key — generate with: openssl rand -hex 32
PEERTUBE_SECRET=change_me_strong_random_secret

# Admin email (for login and password reset)
PEERTUBE_ADMIN_EMAIL=admin@localhost

# PostgreSQL credentials
PEERTUBE_DBNAME=peertube
PEERTUBE_DBUSER=peertube
PEERTUBE_DBPASS=change_me_strong_password

# SMTP (optional — leave blank to disable email notifications)
PEERTUBE_SMTP_HOST=
PEERTUBE_SMTP_PORT=465
PEERTUBE_SMTP_USER=
PEERTUBE_SMTP_PASS=

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

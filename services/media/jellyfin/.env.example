# ===========================================================================
# Jellyfin — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

JELLYFIN_PORT=8096
JELLYFIN_HTTPS_PORT=8920

# Public-facing URL (used for transcoding session URLs)
JELLYFIN_URL=http://localhost:8096

TZ=America/New_York
PUID=1000
PGID=1000
NAS_PATH=/mnt/nas
DATA_PATH=/mnt/nas/appdata

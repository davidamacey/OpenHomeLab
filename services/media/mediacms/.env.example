# ===========================================================================
# MediaCMS — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# PRIVACY TIP: After setup, in the admin panel set:
#   PORTAL_WORKFLOW = private     (require login to browse)
#   REGISTRATION_SYSTEM = closed  (only admin can create accounts)
# ===========================================================================

MEDIACMS_PORT=7950

# Your server's LAN IP or hostname (used in video URLs and email links)
MEDIACMS_HOSTNAME=localhost

# REQUIRED: Django secret key — generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
MEDIACMS_SECRET_KEY=change_me_to_a_long_random_string

# Admin account (created on first start; change password immediately after login)
MEDIACMS_ADMIN_EMAIL=admin@localhost
MEDIACMS_ADMIN_PASSWORD=change_me_immediately

# PostgreSQL credentials
MEDIACMS_DBNAME=mediacms
MEDIACMS_DBUSER=mediacms
MEDIACMS_DBPASS=change_me_strong_password

TZ=America/New_York
DATA_PATH=/mnt/nas/appdata

# ===========================================================================
# Immich — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# Docs: https://immich.app/docs/install/environment-variables
# ===========================================================================

# Immich version — use "release" for latest stable, or pin e.g. "v1.100.0"
IMMICH_VERSION=release

# Upload location (where photos are stored inside the container maps to this host path)
UPLOAD_LOCATION=/mnt/nas/appdata/immich/upload

# Database data directory
DB_DATA_LOCATION=/mnt/nas/appdata/immich/postgres

# ML model cache directory
MODEL_CACHE_LOCATION=/mnt/nas/appdata/immich/model-cache

# Database credentials — use strong random passwords
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_strong_random_password
DB_DATABASE_NAME=immich

# Port (default: 2283)
IMMICH_PORT=2283

TZ=America/New_York

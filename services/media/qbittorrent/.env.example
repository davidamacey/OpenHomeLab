# ===========================================================================
# qBittorrent — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
#
# NOTE: Default password is shown in container logs on first run.
#       Change it immediately after first login.
# ===========================================================================

QBIT_WEBUI_PORT=7460
QBIT_TORRENT_PORT=6881

TZ=America/New_York
PUID=1000
PGID=1000
NAS_PATH=/mnt/nas
DATA_PATH=/mnt/nas/appdata

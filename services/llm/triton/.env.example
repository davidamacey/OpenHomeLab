# ===========================================================================
# Triton + YOLO API — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# Path to Triton model repository (directory with model subdirs)
TRITON_MODELS_PATH=/mnt/nas/triton-models

# Path to YOLO API source code (for volume mount)
YOLO_SRC_PATH=./src

# Ports
TRITON_HTTP_PORT=8000
TRITON_GRPC_PORT=8001
TRITON_METRICS_PORT=8002
YOLO_PORT=8200

TZ=America/New_York

# ===========================================================================
# Open WebUI + vLLM Stack — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# Open WebUI secret key — generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# Docker image tags
WEBUI_DOCKER_TAG=main
OLLAMA_DOCKER_TAG=latest

# Ports
OPENWEBUI_PORT=8010
VLLM_20B_PORT=8012
VLLM_120B_PORT=8011
TIKA_PORT=8009
OLLAMA_PORT=11434

# NAS base path
NAS_PATH=/mnt/nas
TZ=America/New_York

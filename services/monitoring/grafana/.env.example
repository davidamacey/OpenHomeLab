# ===========================================================================
# Grafana + Prometheus — Environment Variables
# Copy to .env and fill in real values. .env is gitignored.
# ===========================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password

# Ports
GRAFANA_PORT=3002
PROMETHEUS_PORT=9090
CADVISOR_PORT=8081    # note: 8080 conflicts with Stirling PDF default
DCGM_PORT=9400

# Prometheus config path (relative or absolute)
PROMETHEUS_CONFIG_PATH=./prometheus.yml
PROMETHEUS_RETENTION=30d

TZ=America/New_York
